# 复制为 secrets.toml 用于本地测试，或在 Streamlit Cloud 控制台粘贴同等内容。
# Cloud 路径：App → Settings → Secrets

[apify]
token = "apify_api_xxxxxxxx"

[gemini]
api_key = "AIzaSyxxxxxxxx"
# 新版 Google AI Studio Auth Key 以 AQ. 开头，同样支持：
# api_key = "AQ.xxxxxxxx"
# model = "gemini-2.5-flash-lite"

[meta]
# Meta Marketing API（meta_ads_analysis_app.py）
# access_token = "EAAxxxxxxxx"
# 多账户（TOML 数组，也可在应用侧边栏填写）
# [[meta.accounts]]
# name = "WearNuage"
# id = "act_123456789"
# [[meta.accounts]]
# name = "Nuage Bra"
# id = "act_987654321"

[llm]
# 可选：预填大模型配置（私有团队部署时使用；公开应用建议让用户在侧边栏自行填写）
# api_key = "sk-xxxxxxxx"
# provider = "OpenAI"
# base_url = "https://api.openai.com/v1"
# model = "gpt-4o-mini"

[email]
# SMTP 发信配置（Gmail 需使用应用专用密码）
# smtp_host = "smtp.gmail.com"
# smtp_port = "587"
# smtp_user = "your@gmail.com"
# smtp_password = "your-app-password"
# from_addr = "your@gmail.com"
# from_name = "跨境电商广告分析报告"
# use_tls = "true"
# default_recipients = "boss@company.com, team@company.com"
