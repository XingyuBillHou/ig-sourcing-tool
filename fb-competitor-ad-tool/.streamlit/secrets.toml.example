# 本地：复制为 secrets.toml（已被 .gitignore 忽略）
# Streamlit Cloud：App → Settings → Secrets，粘贴下方内容并填入真实密钥

[apify]
token = "apify_api_xxxxxxxx"

[gemini]
api_key = "AIzaSyxxxxxxxx"
model = "gemini-3.5-flash"
# 海外服务器（含 Streamlit Cloud）通常留空；仅国内自建服务器可能需要
# proxy_url = "http://127.0.0.1:7890"

[brand]
website = "https://www.nuagewears.com"
# context = "自定义品牌摘要；留空则用内置 Nuage 默认"

