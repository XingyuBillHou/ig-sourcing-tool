# 复制为 .env.cloud 后填入（云端部署用，勿提交 Git）
# cp .env.cloud.example .env.cloud

# === 必填 ===
APIFY_TOKEN=apify_api_xxxxxxxx
GEMINI_API_KEY=AIzaSyxxxxxxxx

# === 可选 ===
GEMINI_MODEL=gemini-3.5-flash
# 海外 VPS 通常留空；国内服务器访问 Gemini 才需要代理
GEMINI_PROXY_URL=

# === 访问域名（有域名则自动 HTTPS；留空则用服务器 IP + HTTP）===
# 示例: ads.yourcompany.com
CADDY_DOMAIN=

# === 可选：访问密码（防止公网裸奔）===
# 生成: docker run --rm caddy:2-alpine caddy hash-password --plaintext '你的密码'
CADDY_BASIC_AUTH_USER=
CADDY_BASIC_AUTH_HASH=

# === 邮件（可选）===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_ADDR=
SMTP_FROM_NAME=FB广告库浅捞工具
EMAIL_DEFAULT_RECIPIENTS=
